# --- LDR Coach backend configuration (12-factor: config via env) ---
# Copy to .env for local non-Docker runs. In Docker, these are supplied
# by docker-compose from the repo-root .env.

# Runtime environment: development | production
ENV=development

# Route prefix for all API endpoints
API_PREFIX=/api

# Database connection (SQLAlchemy URL).
# Local (no Docker) default is SQLite; Docker overrides with Postgres:
#   postgresql+psycopg2://ldr:ldr@db:5432/ldr
DATABASE_URL=sqlite:///./dev.db

# Auth — MUST be overridden with a strong random value in production
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Onboarding — partner invites
INVITE_EXPIRE_DAYS=14
# Base URL used to build the shareable invite link (frontend /join page)
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost,http://localhost:3000

# BeReal — uploaded photos are written here and served at {API_PREFIX}/media
UPLOAD_DIR=uploads
# Minutes after a moment fires that partners may still post
BE_REAL_POST_WINDOW_MINUTES=120
# Largest accepted photo upload, in bytes (default 10 MiB)
BE_REAL_MAX_UPLOAD_BYTES=10485760

# Notifications — turn on to emit (stubbed) partner emails for moments
EMAIL_ENABLED=false
