# Base URL of the FastAPI backend, including the /api/v1 prefix.
# Expo inlines any EXPO_PUBLIC_* variable into the build at bundle time.
#
# Simulator on the same Mac as the backend:
#   EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
# Physical iPhone on the same Wi-Fi (use your Mac's LAN IP, not localhost):
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:8000/api/v1
# Deployed backend (TestFlight builds should point here — must be HTTPS):
#   EXPO_PUBLIC_API_URL=https://api.your-domain.com/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
