# --- LDR Coach: root environment for docker-compose ---
# Copy to .env (which is gitignored) and adjust. Never commit real secrets.

# Public HTTP port for the reverse proxy
HTTP_PORT=80

# Runtime environment: development | production
ENV=production

# --- Postgres ---
POSTGRES_USER=ldr
POSTGRES_PASSWORD=ldr_dev_password
POSTGRES_DB=ldr

# --- Backend auth ---
# Generate a strong value for production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost

# --- Notifications / reminders worker ---
# How often the worker scans for due reminders (seconds)
NOTIFICATIONS_POLL_SECONDS=60
# Default lead time for "your visit is coming up" reminders (days); users can
# override this per-account in their notification preferences
VISIT_REMINDER_DEFAULT_DAYS=3
# Email channel is wired but off until configured (in-app always works)
EMAIL_ENABLED=false
